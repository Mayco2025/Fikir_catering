# Frontend environment variables (prefix with VITE_ to expose to the browser)

# Backend API URL — set this to your deployed backend URL in production
VITE_API_URL=http://localhost:3000/api/submit-order

# EmailJS credentials (from emailjs.com dashboard)
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
